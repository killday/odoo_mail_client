<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="group_email_manager" model="res.groups">
        <field name="name">Email Manager</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="access_fetchmail_server_email_manager_xml" model="ir.model.access">
        <field name="name">fetchmail.server.email.manager.xml</field>
        <field name="model_id" ref="mail.model_fetchmail_server"/>
        <field name="group_id" ref="group_email_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="associated_users_record_rule" model="ir.rule">
        <field name="name">Associated Users Record Rule</field>
        <field name="model_id" ref="model_email_record"/>
        <field name="domain_force">[('associated_users','in', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="email_record_rule_admin_all" model="ir.rule">
        <field name="name">Admin Email Record Full Access</field>
        <field name="model_id" ref="model_email_record"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="incoming_mail_server_record_rule_admin" model="ir.rule">
        <field name="name">Admin fetch mail server record rule</field>
        <field name="model_id" ref="mail.model_fetchmail_server"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="incoming_mail_server_record_rule_user" model="ir.rule">
        <field name="name">User fetch mail server read-only rule</field>
        <field name="model_id" ref="mail.model_fetchmail_server"/>
        <field name="domain_force">['|',('create_uid','=', user.id),('user','=', user.login)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="incoming_mail_server_record_rule_manager" model="ir.rule">
        <field name="name">Manager fetch mail server owned-account rule</field>
        <field name="model_id" ref="mail.model_fetchmail_server"/>
        <field name="domain_force">['|',('create_uid','=', user.id),('user','=', user.login)]</field>
        <field name="groups" eval="[(4, ref('odoo_mail_client.group_email_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>