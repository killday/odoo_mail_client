<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
        <!-- ComposeMail template for composing a new mail -->
    <t t-name="ComposeMail" owl="1">
        <div class="container compose-window" t-ref="root"
             id="send_message" tabindex="-1"
             aria-labelledby="send_message_label" aria-hidden="true"><br />
            <div class="dialog ">
                <form class="form_submit">
                    <div class="content-group">
                        <div class="header d-flex justify-content-between">
                            <h1 class="title fs-5" id="send_message_label"><t t-out="state.title"/></h1>
                            <div class="compose-header-actions">
                                <button class="btn" id="minimizeButton"
                                        type="button"
                                        t-on-click="minimizeMail">
                                    <i class="fa fa-window-minimize"
                                       aria-hidden="true"/>
                                </button>
                                <button class="btn" t-on-click="maximizeMail">
                                    <img src="/odoo_mail_client/static/src/img/expand_icon.svg"
                                         class="btn-icon btn-icon-sm"/>
                                </button>
                                <button type="button" class="btn-close"
                                        aria-label="Close" t-on-click="Close"/>
                            </div>
                        </div>
                        <div class="body">
                            <select class="form-control"
                                    id="sender_account"
                                    t-model="state.senderServerId"
                                    t-on-change="onSenderAccountChange"
                                    t-if="state.senderAccounts.length">
                                <t t-foreach="state.senderAccounts" t-as="account" t-key="account.id">
                                    <option t-att-value="account.id + ''">
                                        <t t-out="account.user or account.name"/>
                                    </option>
                                </t>
                            </select>
                            <br/>
                            <label for="signature_selector" class="compose-field-label">Signature</label>
                            <div class="d-flex align-items-center" t-if="availableSignatures.length">
                                <select class="form-control"
                                        id="signature_selector"
                                        t-model="state.selectedSignatureId"
                                        t-on-change="onSignatureChange">
                                    <t t-foreach="availableSignatures" t-as="signature" t-key="signature.id">
                                        <option t-att-value="signature.id + ''">
                                            <t t-out="signature.name"/>
                                        </option>
                                    </t>
                                </select>
                                <button type="button"
                                        class="btn btn-secondary"
                                        style="margin-left:8px;"
                                        t-on-click="openSignatureManager">Manage</button>
                            </div>
                            <div class="d-flex align-items-center" t-else="">
                                <span style="font-size:12px;color:#666;">No signature configured</span>
                                <button type="button"
                                        class="btn btn-secondary"
                                        style="margin-left:8px;"
                                        t-on-click="openSignatureManager">Create</button>
                            </div>
                            <br/>
                            <label for="Recipient" class="compose-field-label">To</label>
                            <div style="position:relative;">
                                <input type="text" class="form-control"
                                       id="Recipient"
                                       t-model="state.recipient"
                                       t-on-input="onRecipientInput"
                                       aria-describedby="emailHelp"
                                       placeholder="Type name or email"/>
                                <div t-if="state.recipientSuggestions.length"
                                     style="position:absolute;left:0;right:0;z-index:1000;background:#fff;border:1px solid #ddd;border-top:none;max-height:180px;overflow:auto;">
                                    <t t-foreach="state.recipientSuggestions" t-as="suggestion" t-key="suggestion.id">
                                        <button type="button"
                                                class="btn w-100 text-start"
                                                style="border-radius:0;padding:8px 10px;"
                                                t-att-data-suggestion-id="suggestion.id"
                                                t-on-mousedown="onRecipientSuggestionMouseDown">
                                            <t t-out="suggestion.label"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                            <br/>
                            <label for="cc" class="compose-field-label">Cc</label>
                            <div style="position:relative;">
                                <input type="text" class="form-control"
                                       id="cc"
                                       t-model="state.cc"
                                       t-on-input="onCcInput"
                                       aria-describedby="emailHelp"
                                       placeholder="Type name or email"/>
                                <div t-if="state.ccSuggestions.length"
                                     style="position:absolute;left:0;right:0;z-index:1000;background:#fff;border:1px solid #ddd;border-top:none;max-height:180px;overflow:auto;">
                                    <t t-foreach="state.ccSuggestions" t-as="suggestion" t-key="suggestion.id">
                                        <button type="button"
                                                class="btn w-100 text-start"
                                                style="border-radius:0;padding:8px 10px;"
                                                t-att-data-suggestion-id="suggestion.id"
                                                t-on-mousedown="onCcSuggestionMouseDown">
                                            <t t-out="suggestion.label"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                            <br/>
                            <label for="bcc" class="compose-field-label">Bcc</label>
                            <div style="position:relative;">
                                <input type="text" class="form-control"
                                       id="bcc"
                                       t-model="state.bcc"
                                       t-on-input="onBccInput"
                                       aria-describedby="emailHelp"
                                       placeholder="Type name or email"/>
                                <div t-if="state.bccSuggestions.length"
                                     style="position:absolute;left:0;right:0;z-index:1000;background:#fff;border:1px solid #ddd;border-top:none;max-height:180px;overflow:auto;">
                                    <t t-foreach="state.bccSuggestions" t-as="suggestion" t-key="suggestion.id">
                                        <button type="button"
                                                class="btn w-100 text-start"
                                                style="border-radius:0;padding:8px 10px;"
                                                t-att-data-suggestion-id="suggestion.id"
                                                t-on-mousedown="onBccSuggestionMouseDown">
                                            <t t-out="suggestion.label"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                            <br/>
                            <input type="text" class="form-control"
                                   id="subject" t-model="state.subject"
                                   aria-describedby="emailHelp"
                                   placeholder="Subject"/>
                            <br/>
                            <textarea class="dd form-control" id="content"
                                      rows="5" t-model="state.content"
                                      t-on-input="onContentInput"
                                      style="height:200px">

                            </textarea>

                            <br/>
                                <t t-foreach="state.attachedFiles" t-as="attachment" t-key="attachment_index">
                                    <div class="custom-input"
                                         style="width: max-content;min-width:240px;height: 23px;background-color: darkgrey;font: icon;display:flex;justify-content:space-between;align-items: center;padding:0.5rem;margin:0.5rem 0;">
                                         <t t-out="attachment.name"/>
                                        <button type="button" class="btn close-button" id="attachments"
                                                style="margin-left: 10px;line-height:0px;"
                                            t-on-click="() => closeInput(attachment_index)">x</button>
                                    </div>
                                </t>
                        </div>
                        <div class="footer d-flex justify-content-end">
                            <button type="submit"
                                    style="border-radius: 15px; width: 85px;"
                                    class="btn btn-primary"
                                    t-on-click="sentMail">Send</button>
                            <div class="image-upload"
                                 t-on-click="attachmentAction">
                                <label>
                                    <img src="/odoo_mail_client/static/src/img/attachment.svg"/>
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </t>
</templates>
