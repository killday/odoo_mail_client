<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!--    form (email record) view-->
    <record id="email_form_view" model="ir.ui.view">
        <field name="name">email.record.form</field>
        <field name="model">email.record</field>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <form string="Compose Email">
                <header>
                    <button class="oe_highlight" type="object" name="send_email" string="Send"
                            context="{'key':'Sent'}"
                            invisible="type != 'draft' or parent_exists"
                            confirm="Are you sure you want to send this email?"/>
                    <button class="oe_highlight" type="object" name="reply_popup" string="Reply"
                            context="{'key':'Replied'}"
                            invisible="type == 'draft' or parent_exists"/>
                    <button class="oe_highlight" type="object" name="forward_popup" string="Forward"
                            context="{'key':'Forwarded'}"
                            invisible="type == 'draft' or parent_exists"/>
                    <button type="object" name="action_mark_read" string="Mark Read"
                        invisible="type == 'draft' or is_read"/>
                    <button type="object" name="action_mark_unread" string="Mark Unread"
                        invisible="type == 'draft' or not is_read"/>
                    <button type="object" name="action_toggle_starred" string="Star/Unstar"
                        invisible="type == 'draft'"/>
                    <button type="object" name="action_toggle_archived" string="Archive/Unarchive"
                        invisible="type == 'draft'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="subject" class="oe_edit_only"/>
                        <h1>
                            <field name="subject" readonly="type != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="to" widget="many2many_tags"
                                   required="not cc and type in ['draft', 'outgoing']"
                                   readonly="type != 'draft'"
                                   options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="cc" widget="many2many_tags" readonly="type != 'draft'"
                                   options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="bcc" widget="many2many_tags" readonly="type != 'draft'"
                                options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="sender"/>
                            <field name="incoming_server_id"
                                   string="From Account"
                                   invisible="type != 'draft'"
                                   readonly="parent_exists"
                                   options="{'no_create': True}"/>
                                                    </group>
                        <group>
                            <field name="date_time"/>
                            <field name="type"/>
                            <field name="message_id" invisible="1"/>
                            <field name="external_message_id" invisible="1"/>
                            <field name="in_reply_to" invisible="1"/>
                            <field name="references_header" invisible="1"/>
                            <field name="parent_exists" invisible="1"/>
                            <field name="parent_message_id" readonly="1"/>
                            <field name="is_read" readonly="1"/>
                            <field name="is_starred" readonly="1"/>
                            <field name="is_archived" readonly="1"/>
                            <field name="priority" widget="priority"/>
                            <field name="tags" widget="many2many_tags"
                                   options="{'color_field': 'color', 'no_create_edit': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Email Body">
                            <field name="body" readonly="type != 'draft'"/>
                            <group>
                                <field name="attachments" widget="many2many_binary"
                                       readonly="type != 'draft'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <footer invisible="type != 'draft' or not parent_exists">
                    <button name="send_email" string="Save and Send" type="object" class="btn-primary o_mail_send"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>


            </form>
        </field>
    </record>

    <!--  Tree view of email record  -->
    <record id="emails_tree_view" model="ir.ui.view">
        <field name="name">email.record.tree</field>
        <field name="model">email.record</field>
        <field name="arch" type="xml">
            <list default_order="date_time desc" decoration-muted="is_read">
            <button name="action_toggle_starred" type="object" icon="fa-star" string="Star"
                invisible="is_starred"/>
            <button name="action_toggle_starred" type="object" icon="fa-star-o" string="Unstar"
                invisible="not is_starred"/>
            <button name="action_mark_read" type="object" string="Read" invisible="is_read"/>
            <button name="action_mark_unread" type="object" string="Unread" invisible="not is_read"/>
            <button name="action_toggle_archived" type="object" string="Archive"
                invisible="is_archived"/>
            <button name="action_toggle_archived" type="object" string="Unarchive"
                invisible="not is_archived"/>
                <field name="to" widget="many2many_tags"/>
                <field name="sender"/>
                <field name="subject"/>
                <field name="date_time"/>
                <field name="type"/>
                <field name="parent_message_id" optional="1"/>
            <field name="is_read" optional="1"/>
            <field name="is_starred" optional="1"/>
            <field name="is_archived" optional="1"/>
                <field name="priority" optional="1"/>
                <field name="tags" widget="many2many_tags" optional="1"/>
                <field name="attachment_icon" invisible="1"/>
                <button string="Has attachment" icon="fa-paperclip" colspan='1'
                        invisible="not attachment_icon"/>
            </list>
        </field>
    </record>

</odoo>