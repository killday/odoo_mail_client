<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mail_signature_tree" model="ir.ui.view">
        <field name="name">mail.signature.tree</field>
        <field name="model">mail.signature</field>
        <field name="arch" type="xml">
            <list string="Signatures">
                <field name="name"/>
                <field name="server_id"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_mail_signature_form" model="ir.ui.view">
        <field name="name">mail.signature.form</field>
        <field name="model">mail.signature</field>
        <field name="arch" type="xml">
            <form string="Signature Template">
                <sheet>
                    <div class="o_mail_signature_editor">
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="e.g. Support Team Signature"/>
                            </h1>
                            <div class="text-muted">
                                Build a reusable signature template with multiple lines and contact details.
                            </div>
                        </div>

                        <group col="4" class="mt16">
                            <field name="server_id"/>
                            <field name="is_default"/>
                            <field name="active"/>
                            <field name="user_id" readonly="1"/>
                        </group>

                        <notebook>
                            <page string="Editor">
                                <group col="1">
                                    <label for="body" string="Signature Content"/>
                                    <field name="body" widget="html" nolabel="1"/>
                                    <div class="text-muted o_mail_signature_hint">
                                        Tip: use line breaks to create a clean signature block.
                                    </div>
                                </group>
                            </page>
                            <page string="Preview">
                                <group col="1">
                                    <div class="o_form_label">Live Preview</div>
                                    <field name="preview_html" widget="html" nolabel="1" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mail_signatures" model="ir.actions.act_window">
        <field name="name">Signatures</field>
        <field name="res_model">mail.signature</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("user_id", "=", uid)]</field>
        <field name="context">{"default_user_id": uid}</field>
    </record>
</odoo>
